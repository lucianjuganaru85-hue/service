@page "/adauga-client"
@using AutoService.Data
@using AutoService.Models
@inject ApplicationDbContext DbContext
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="container mt-5">
    <h2 class="mb-4 fw-bold">➕ Adaugă Client Nou</h2>
    <EditForm Model="noulClient" OnValidSubmit="SalveazaClient" FormName="AddClientForm">
        <DataAnnotationsValidator />
        <div class="card p-4 shadow-sm border-0 rounded-4">
            <div class="mb-3">
                <label class="form-label fw-bold">Prenume</label>
                <InputText @bind-Value="noulClient!.FirstName" class="form-control" />
                <ValidationMessage For="@(() => noulClient!.FirstName)" class="text-danger small" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Nume</label>
                <InputText @bind-Value="noulClient!.LastName" class="form-control" />
                <ValidationMessage For="@(() => noulClient!.LastName)" class="text-danger small" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Telefon</label>
                <InputText @bind-Value="noulClient!.PhoneNumber" class="form-control" />
                <ValidationMessage For="@(() => noulClient!.PhoneNumber)" class="text-danger small" />
            </div>
            <div class="text-center mt-3">
                <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold shadow">Salvează Client</button>
            </div>
        </div>
    </EditForm>
</div>

@code {
    [SupplyParameterFromForm(Name = "AddClientForm")]
    public Client? noulClient { get; set; }

    protected override void OnInitialized() => noulClient ??= new();

    private async Task SalveazaClient()
    {
        if (noulClient == null) return;
        noulClient.CreatedAt = DateTime.Now;
        noulClient.Email ??= ""; // Evităm NULL-ul în DB
        DbContext.Clients.Add(noulClient);
        await DbContext.SaveChangesAsync();
        Navigation.NavigateTo("/clienti");
    }
}