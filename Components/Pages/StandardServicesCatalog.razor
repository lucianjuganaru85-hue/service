@page "/catalog-servicii"
@using AutoService.Data
@using AutoService.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Administrare Catalog - Crox ERP</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-0">🏷️ Catalog Servicii Standard</h2>
            <p class="text-muted small">Configurează prețurile și timpul estimat pentru intervenții rapide.</p>
        </div>
        <button class="btn btn-outline-secondary fw-bold shadow-sm" @onclick='() => JS.InvokeVoidAsync("history.back")'>
            ⬅️ Înapoi
        </button>
    </div>

    <div class="row g-4">
        @* FORMULAR ADĂUGARE / EDITARE *@
        <div class="col-lg-4">
            <div class="card shadow border-0 rounded-4 p-4 sticky-top" style="top: 20px;">
                <h5 class="fw-bold mb-3">@(editingService.Id == 0 ? "➕ Adaugă Serviciu Nou" : "📝 Editează Serviciu")</h5>
                
                <div class="mb-3">
                    <label class="small fw-bold text-muted">Denumire Serviciu</label>
                    <input class="form-control border-primary" @bind="editingService.Name" placeholder="ex: Schimb Ulei + Filtre" />
                </div>
                
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="small fw-bold text-muted">Preț (lei)</label>
                        <input type="number" class="form-control border-primary text-center" @bind="editingService.DefaultPrice" />
                    </div>
                    <div class="col-6 mb-3">
                        <label class="small fw-bold text-muted">Timp (ore)</label>
                        <input type="number" step="0.1" class="form-control border-primary text-center" @bind="editingService.DefaultHours" />
                    </div>
                </div>

                <div class="d-grid gap-2 mt-2">
                    <button class="btn btn-primary fw-bold" @onclick="SalveazaServiciu">
                        @(editingService.Id == 0 ? "Salvează în Catalog" : "Actualizează Prețuri")
                    </button>
                    @if (editingService.Id != 0)
                    {
                        <button class="btn btn-light text-muted btn-sm" @onclick="AnuleazaEditarea">Anulează Editarea</button>
                    }
                </div>
            </div>
        </div>

        @* LISTĂ SERVICII EXISTENTE *@
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-light py-3 border-0">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">🔍</span>
                        <input type="text" class="form-control border-start-0" placeholder="Caută serviciu în listă..." @bind="searchTerm" @bind:event="oninput" />
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-center">
                        <thead class="table-dark small text-uppercase">
                            <tr>
                                <th class="ps-4 text-start">Denumire</th>
                                <th>Timp Estimat</th>
                                <th>Preț Standard</th>
                                <th>Acțiuni</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (listaServicii == null)
                            {
                                <tr><td colspan="4" class="py-5 text-muted small">Se încarcă catalogul...</td></tr>
                            }
                            else
                            {
                                @foreach (var s in listaFiltrata)
                                {
                                    <tr class="@(editingService.Id == s.Id ? "table-info" : "")">
                                        <td class="ps-4 text-start fw-bold">@s.Name</td>
                                        <td><span class="badge bg-light text-dark border px-3">@s.DefaultHours.ToString("0.0") h</span></td>
                                        <td class="fw-bold text-primary">@s.DefaultPrice.ToString("N0") lei</td>
                                        <td>
                                            <div class="btn-group">
                                                <button class="btn btn-sm btn-outline-info" @onclick="() => PregatesteEditare(s)">✏️</button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => StergeServiciu(s)">🗑️</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover { background-color: rgba(0,123,255,0.05); transition: 0.2s; }
    .sticky-top { z-index: 100; }
</style>

@code {
    private List<StandardService>? listaServicii;
    private StandardService editingService = new();
    private string searchTerm = "";

    protected override async Task OnInitializedAsync() {
        await IncarcaCatalog();
    }

    private async Task IncarcaCatalog() {
        listaServicii = await DbContext.StandardServices.OrderBy(s => s.Name).ToListAsync();
    }

    private IEnumerable<StandardService> listaFiltrata => 
        string.IsNullOrWhiteSpace(searchTerm) ? listaServicii : 
        listaServicii?.Where(s => s.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    private void PregatesteEditare(StandardService s) {
        editingService = new StandardService {
            Id = s.Id,
            Name = s.Name,
            DefaultPrice = s.DefaultPrice,
            DefaultHours = s.DefaultHours
        };
    }

    private void AnuleazaEditarea() {
        editingService = new();
    }

    private async Task SalveazaServiciu() {
        if (string.IsNullOrWhiteSpace(editingService.Name)) return;

        if (editingService.Id == 0) {
            DbContext.StandardServices.Add(editingService);
        } else {
            var existent = await DbContext.StandardServices.FindAsync(editingService.Id);
            if (existent != null) {
                existent.Name = editingService.Name;
                existent.DefaultPrice = editingService.DefaultPrice;
                existent.DefaultHours = editingService.DefaultHours;
            }
        }

        await DbContext.SaveChangesAsync();
        editingService = new();
        await IncarcaCatalog();
    }

    private async Task StergeServiciu(StandardService s) {
        bool confirmat = await JS.InvokeAsync<bool>("confirm", $"Sigur vrei să ștergi '{s.Name}' din catalog?");
        if (confirmat) {
            DbContext.StandardServices.Remove(s);
            await DbContext.SaveChangesAsync();
            await IncarcaCatalog();
        }
    }
}