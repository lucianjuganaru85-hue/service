@page "/angajati"
@using AutoService.Data
@using AutoService.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-info fw-bold mb-0">👥 Gestiune Echipă</h2>
            <p class="text-muted small">Monitorizare status și activitate angajați.</p>
        </div>
        @* BUTONUL ACASĂ REPARAT *@
        <div class="d-flex gap-2">
            <a href="/adaugare-angajat" class="btn btn-info text-white fw-bold shadow-sm">➕ Angajat Nou</a>
            <a href="/" class="btn btn-outline-secondary shadow-sm">🏠 Acasă</a>
        </div>
    </div>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 text-start">Nume Prenume</th>
                        <th>Specializare</th>
                        <th>Status Dinamic</th>
                        <th>Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    @if (listaAngajati != null)
                    {
                        @foreach (var angajat in listaAngajati)
                        {
                            bool esteOcupat = angajat.IsActive && angajat.AssignedAppointments.Any(a => a.Status == "În Lucru");
                            string statusText = !angajat.IsActive ? "Inactiv" : (esteOcupat ? "Ocupat (La Rampă)" : "Disponibil");
                            string statusClass = !angajat.IsActive ? "bg-secondary" : (esteOcupat ? "bg-warning text-dark" : "bg-success");

                            <tr>
                                <td class="ps-4 text-start fw-bold">@angajat.FirstName @angajat.LastName</td>
                                <td><span class="badge bg-light text-primary border border-primary px-3">@angajat.Specialization</span></td>
                                <td><span class="badge @statusClass rounded-pill px-3 py-2">@statusText</span></td>
                                <td>
                                    <div class="btn-group shadow-sm">
                                        <a href="/agenda-angajat/@angajat.Id" class="btn btn-sm btn-info text-white">📅 Agenda</a>
                                        <button class="btn btn-sm @(angajat.IsActive ? "btn-outline-danger" : "btn-outline-success")" @onclick="() => ToggleActive(angajat)">
                                            @(angajat.IsActive ? "Suspendă" : "Activează")
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Employee>? listaAngajati;
    protected override async Task OnInitializedAsync() => await IncarcaDate();

    private async Task IncarcaDate() {
        listaAngajati = await DbContext.Employees
            .Include(e => e.AssignedAppointments)
            .OrderBy(e => e.LastName).ToListAsync();
    }

    private async Task ToggleActive(Employee emp) {
        emp.IsActive = !emp.IsActive;
        await DbContext.SaveChangesAsync();
        await IncarcaDate();
    }
}