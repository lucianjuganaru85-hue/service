@page "/clienti"
@using AutoService.Data
@using AutoService.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Clienți - Crox ERP</PageTitle>

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold text-dark mb-0">👥 Gestiune Clienți</h4>
            <p class="text-muted small mb-0">Administrare bază de date clienți</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-primary fw-bold shadow-sm" @onclick="DeschideAdaugare">➕ Client Nou</button>
            <a href="/" class="btn btn-sm btn-dark shadow-sm">🏠 Acasă</a>
        </div>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-6">
            <input type="text" class="form-control form-control-sm shadow-sm" 
                   placeholder="Caută nume, telefon sau CUI..." 
                   @bind="searchTerm" @bind:event="oninput" />
        </div>
    </div>

    <div class="card shadow border-0 rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0 text-center" style="font-size: 0.85rem;">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-3 text-start">Nume Complet</th>
                        <th>Contact</th>
                        <th>Locație</th>
                        <th>Tip</th>
                        <th>CUI / RegCom</th>
                        <th class="pe-3 text-end">Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    @if (listaFiltrata == null) {
                        <tr><td colspan="6" class="py-4 text-muted">Se încarcă...</td></tr>
                    } else if (!listaFiltrata.Any()) {
                        <tr><td colspan="6" class="py-4 text-muted italic">Niciun client găsit.</td></tr>
                    } else {
                        @foreach (var c in listaFiltrata) {
                            <tr>
                                <td class="ps-3 text-start fw-bold">@c.FirstName @c.LastName</td>
                                <td>@c.PhoneNumber</td>
                                <td class="small">@(string.IsNullOrEmpty(c.City) ? "-" : $"{c.City}, {c.County}")</td>
                                <td>
                                    <span class="badge @(c.IsCompany ? "bg-info" : "bg-secondary") rounded-pill">
                                        @(c.IsCompany ? "🏢 Firmă" : "👤 Persoană")
                                    </span>
                                </td>
                                <td class="small">@(c.IsCompany ? $"{c.CUI} / {c.RegCom}" : "-")</td>
                                <td class="pe-3 text-end">
                                    <div class="btn-group shadow-sm">
                                        <button class="btn btn-xs btn-outline-primary" @onclick="() => DeschideEditare(c)">✏️</button>
                                        <button class="btn btn-xs btn-outline-dark" @onclick="() => StergeClient(c)">🗑️</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (isModalOpen && editingClient != null)
{
    <div class="custom-modal-backdrop" @onclick="() => isModalOpen = false"></div>
    <div class="custom-modal-content shadow-lg p-4 animate__animated animate__fadeInDown">
        <h5 class="fw-bold mb-3 border-bottom pb-2">@(editingClient.Id == 0 ? "👤 Client Nou" : "✏️ Editare Client")</h5>
        <div class="row g-2 text-start">
            <div class="col-6">
                <label class="small fw-bold">Prenume</label>
                <input type="text" class="form-control form-control-sm" @bind="editingClient.FirstName" />
            </div>
            <div class="col-6">
                <label class="small fw-bold">Nume</label>
                <input type="text" class="form-control form-control-sm" @bind="editingClient.LastName" />
            </div>
            <div class="col-6">
                <label class="small fw-bold">Telefon</label>
                <input type="text" class="form-control form-control-sm" @bind="editingClient.PhoneNumber" />
            </div>
            <div class="col-6">
                <label class="small fw-bold">Email</label>
                <input type="text" class="form-control form-control-sm" @bind="editingClient.Email" />
            </div>
            <div class="col-6">
                <label class="small fw-bold">Oraș</label>
                <input type="text" class="form-control form-control-sm" @bind="editingClient.City" />
            </div>
            <div class="col-6">
                <label class="small fw-bold">Județ</label>
                <input type="text" class="form-control form-control-sm" @bind="editingClient.County" />
            </div>
            <div class="col-12">
                <div class="form-check form-switch py-2">
                    <input class="form-check-input" type="checkbox" @bind="editingClient.IsCompany">
                    <label class="form-check-label small fw-bold">Persoană Juridică (Firmă)</label>
                </div>
            </div>
            @if (editingClient.IsCompany) {
                <div class="col-6">
                    <label class="small fw-bold">CUI</label>
                    <input type="text" class="form-control form-control-sm" @bind="editingClient.CUI" />
                </div>
                <div class="col-6">
                    <label class="small fw-bold">Reg. Com.</label>
                    <input type="text" class="form-control form-control-sm" @bind="editingClient.RegCom" />
                </div>
            }
            <div class="col-12">
                <label class="small fw-bold">Adresă</label>
                <textarea class="form-control form-control-sm" rows="2" @bind="editingClient.Address"></textarea>
            </div>
        </div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button class="btn btn-secondary btn-sm" @onclick="() => isModalOpen = false">Anulează</button>
            <button class="btn btn-primary btn-sm px-4 fw-bold" @onclick="SalveazaClient">Salvează</button>
        </div>
    </div>
}

<style>
    .btn-xs { padding: 0.2rem 0.5rem; font-size: 0.75rem; }
    .custom-modal-backdrop { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1000; }
    .custom-modal-content { position: fixed; top: 10%; left: 50%; transform: translateX(-50%); width: 500px; background: white; border-radius: 12px; z-index: 1001; }
</style>

@code {
    private List<Client>? listaClienti;
    private string searchTerm = "";
    private Client? editingClient;
    private bool isModalOpen = false;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData() {
        listaClienti = await DbContext.Clients
            .Where(c => !c.IsDeleted)
            .OrderByDescending(c => c.Id)
            .ToListAsync();
    }

    private IEnumerable<Client>? listaFiltrata => 
        string.IsNullOrWhiteSpace(searchTerm) ? listaClienti : 
        listaClienti?.Where(c => c.LastName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                                 c.FirstName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                                 (c.PhoneNumber?.Contains(searchTerm) ?? false));

    private void DeschideAdaugare() { editingClient = new Client(); isModalOpen = true; }
    private void DeschideEditare(Client c) { editingClient = c; isModalOpen = true; }

    private async Task SalveazaClient() {
        if (editingClient!.Id == 0) DbContext.Clients.Add(editingClient);
        await DbContext.SaveChangesAsync();
        isModalOpen = false;
        await LoadData();
    }

    private async Task StergeClient(Client c) {
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"Ștergi clientul {c.FirstName} {c.LastName}?");
        if (confirm) {
            c.IsDeleted = true;
            await DbContext.SaveChangesAsync();
            await LoadData();
        }
    }
}