@page "/arhiva-facturi"
@using AutoService.Data
@using AutoService.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Arhivă Facturi Furnizori - Crox ERP</PageTitle>

<div class="container-fluid mt-4">
    @* ANTET CU BUTOANE DE NAVIGARE *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">📑 Arhivă Facturi Furnizori</h2>
            <p class="text-muted small">Monitorizarea scadențelor și a plăților către parteneri.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary shadow-sm" @onclick='() => JS.InvokeVoidAsync("history.back")'>
                ⬅️ Înapoi
            </button>
            <a href="/" class="btn btn-dark shadow-sm">🏠 Acasă</a>
        </div>
    </div>

    @* FILTRE RAPIDE *@
    <div class="card shadow-sm border-0 p-3 mb-4 rounded-4 bg-light">
        <div class="row g-3 align-items-center">
            <div class="col-md-4">
                <input type="text" class="form-control" placeholder="Caută după Nr. Factură sau Furnizor..." 
                       @bind="searchTerm" @bind:event="oninput" />
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="filterStatus">
                    <option value="Toate">Toate Facturile</option>
                    <option value="Depasite">🚨 Depășite</option>
                    <option value="SaptamanaAsta">📅 Scad săptămâna asta</option>
                </select>
            </div>
            <div class="col-md-5 text-end">
                <span class="badge bg-danger p-2 me-2">Datorii Total: @listaFacturi?.Where(f => f.DueDate < DateTime.Now).Sum(f => f.TotalValue).ToString("N2") lei</span>
                <span class="badge bg-dark p-2">Total General: @listaFacturi?.Sum(f => f.TotalValue).ToString("N2") lei</span>
            </div>
        </div>
    </div>

    @* TABELUL DE FACTURI *@
    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="bg-dark text-white small text-uppercase">
                    <tr>
                        <th class="ps-4 text-start">Nr. Factură</th>
                        <th>Furnizor</th>
                        <th>Data Emiterii</th>
                        <th>Data Scadenței</th>
                        <th>Valoare</th>
                        <th>Status Scadență</th>
                        <th>Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    @if (listaFiltrata == null)
                    {
                        <tr><td colspan="7" class="py-5 text-muted">Se încarcă arhiva financiară...</td></tr>
                    }
                    else if (!listaFiltrata.Any())
                    {
                        <tr><td colspan="7" class="py-5 text-muted">Nu am găsit nicio factură conform filtrelor tale.</td></tr>
                    }
                    else
                    {
                        @foreach (var f in listaFiltrata)
                        {
                            bool eDepasita = f.DueDate < DateTime.Now;
                            bool eAproape = !eDepasita && (f.DueDate - DateTime.Now).TotalDays <= 7;

                            <tr class="@(eDepasita ? "row-overdue" : "")">
                                <td class="ps-4 text-start fw-bold">@f.InvoiceNumber</td>
                                <td class="fw-bold text-primary">@f.Supplier?.Name</td>
                                <td>@f.InvoiceDate.ToString("dd.MM.yyyy")</td>
                                <td class="fw-bold @(eDepasita ? "text-danger" : (eAproape ? "text-warning" : ""))">
                                    @f.DueDate.ToString("dd.MM.yyyy")
                                </td>
                                <td class="fw-bold">@f.TotalValue.ToString("N2") lei</td>
                                <td>
                                    @if (eDepasita)
                                    {
                                        <span class="badge bg-danger rounded-pill px-3">🚨 DEPĂȘITĂ</span>
                                    }
                                    else if (eAproape)
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3">⏳ SCADE CURÂND</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-pill px-3">✅ ÎN TERMEN</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-dark shadow-sm" @onclick="() => VeziDetalii(f.Id)">👁️ Vezi NIR</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .row-overdue { background-color: rgba(220, 53, 69, 0.05) !important; }
    .table-hover tbody tr:hover { filter: brightness(0.95); transition: 0.2s; }
</style>

@code {
    private List<SupplierInvoice>? listaFacturi;
    private string searchTerm = "";
    private string filterStatus = "Toate";

    protected override async Task OnInitializedAsync()
    {
        await LoadInvoices();
    }

    private async Task LoadInvoices()
    {
        listaFacturi = await DbContext.SupplierInvoices
            .Include(f => f.Supplier)
            .OrderByDescending(f => f.DueDate)
            .ToListAsync();
    }

    private IEnumerable<SupplierInvoice>? listaFiltrata
    {
        get
        {
            if (listaFacturi == null) return null;

            var result = listaFacturi.AsEnumerable();

            // Filtru search
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                result = result.Where(f => f.InvoiceNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                                           (f.Supplier?.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            // Filtru Status
            if (filterStatus == "Depasite")
            {
                result = result.Where(f => f.DueDate < DateTime.Now);
            }
            else if (filterStatus == "SaptamanaAsta")
            {
                // Calculăm sfârșitul săptămânii (Luni e începutul)
                var startOfWeek = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + (int)DayOfWeek.Monday);
                var endOfWeek = startOfWeek.AddDays(7);
                result = result.Where(f => f.DueDate >= DateTime.Today && f.DueDate <= endOfWeek);
            }

            return result;
        }
    }

    private void VeziDetalii(int id)
    {
        // Aici poți face o pagină de vizualizare NIR sau modal
        // Navigation.NavigateTo($"/detalii-factura/{id}");
    }
}